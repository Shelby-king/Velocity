# Auto detect text files and normalize line endings to LF in the repository
* text=auto eol=lf

# Bash scripts must always use LF (Unix line endings) even on Windows
*.sh text eol=lf
*.bash text eol=lf
run.bash text eol=lf

# Windows scripts should use CRLF
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.wasm binary
*.exe binary
*.dll binary
*.so binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary

# Explicitly set language for Dockerfiles
Dockerfile text eol=lf
*.dockerfile text eol=lf
